# OpenRouter API Configuration
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Next.js Environment
NODE_ENV=development

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://www.midtownvegascondos.com
NEXT_PUBLIC_AGENT_IMAGE_URL=https://pub-720ca9b7443b47be981def05abd3d7f0.r2.dev/shared/agent/dr-jan-duffy-headshot.jpg

# Google Search Console — HTML tag verification content (not the full meta tag)
# GSC → Settings → Ownership verification → HTML tag → paste the content= value only
GOOGLE_SITE_VERIFICATION=

# Google OAuth 2.0 Web Client ID (Cloud Console → APIs & Services → Credentials)
# Authorized JavaScript origins should include https://www.midtownvegascondos.com
# Maps / reviews always use the GBP office: 921 South Main Street, Las Vegas, NV 89101
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=584887863848-6iaq27hfjgoi7b32huhhmtjs46u36f4o.apps.googleusercontent.com

# Optional — Bing Webmaster Tools meta tag content
BING_SITE_VERIFICATION=
